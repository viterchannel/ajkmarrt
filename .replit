modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[userenv]

[userenv.shared]
NODE_ENV = "development"
ALLOW_DEV_OTP = "true"
LOG_LEVEL = "info"
API_PORT = "8080"
VITE_API_PROXY_TARGET = "http://127.0.0.1:5000"
ALLOWED_ORIGINS = "*"
PORT = "5000"
ADMIN_DEV_PORT = "3000"
VENDOR_DEV_PORT = "3001"
RIDER_DEV_PORT = "3002"

[userenv.production]
JWT_SECRET = "00cfa1d4be81e8c6212c8807c49624e86e9a1a13672df4cba291fb220cc4e3f748b510ee1184e29b91553105db464df606b1a2fed9f519d887d0e71a700e2f52"

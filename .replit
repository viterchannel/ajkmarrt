TOTP_ENCRYPTION_KEY = "aa2b86b7e0cce15385fe1ca8575a3d2835e421f9c9208b2c5b25e3190c319a23"
HMAC_OTP_SECRET = "b0277a91b31e9c710c0b5be29f2c55b600206a7223f4e7590b98e36a03a937fd"
OTP_HMAC_SECRET = "6b79fd903ebcb93f1914fd4eac6c3f606856ada16208abcd5886a4805f017e7a"
ADMIN_ACCESS_TOKEN_SECRET = "b0604436b673bbfa490dab5563632f47c3e554638836702d55ea924d7c6f37c051a823a1dba741ae9fc7bf837ff0200b105f95986b0ddf9d99f535307ecbd9fb"
ADMIN_REFRESH_TOKEN_SECRET = "6af31d988e0ea8de94144c0ac93880c447d51933e4d723c7db174ca4438469f17398c784ab1f6785b76bd734ee68b36d87742fbfce170b9f096877bb411ab47e"
ADMIN_CSRF_SECRET = "5520a32cb4fd2c8dcd36cab70c5ac267ca04ecdab6814609859ee99a8c1cbd57"
ERROR_REPORT_HMAC_SECRET = "2791e7bd86d77a9535aadb431e32e772acce895fd0f36ecea80f56e782744a47"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 3004
externalPort = 6800

[[ports]]
localPort = 3005
externalPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 20716
externalPort = 5173

[[ports]]
localPort = 20717
externalPort = 8099

[[ports]]
localPort = 21463
externalPort = 6000

[[ports]]
localPort = 21464
externalPort = 8008

[[ports]]
localPort = 22969
externalPort = 3003

[[ports]]
localPort = 22970
externalPort = 8080

[[ports]]
localPort = 23744
externalPort = 4200

[[ports]]
localPort = 23745
externalPort = 9000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/api-server && PORT=5000 PORT_FALLBACK_ENABLE=false NODE_ENV=development node ./scripts/start-with-restart.mjs"
waitForPort = 5000

[[workflows.workflow]]
name = "Admin Panel"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 BASE_PATH=/admin pnpm --filter @workspace/admin run dev"
waitForPort = 3000

[[workflows.workflow]]
name = "Vendor App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 BASE_PATH=/vendor pnpm --filter @workspace/vendor-app run dev"
waitForPort = 3001

[[workflows.workflow]]
name = "Rider App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3002 BASE_PATH=/rider pnpm --filter @workspace/rider-app run dev"
waitForPort = 3002

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin Panel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Vendor App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rider App"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "NODE_ENV=production node apps/api-server/dist/index.mjs"]
build = ["bash", "-c", "BASE_PATH=/admin pnpm --filter @workspace/admin run build && BASE_PATH=/vendor pnpm --filter @workspace/vendor-app run build && BASE_PATH=/rider pnpm --filter @workspace/rider-app run build && pnpm --filter @workspace/api-server run build"]
